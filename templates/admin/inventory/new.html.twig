{% extends 'admin/layout.html.twig' %}

{% block admin_body %}
<!-- HEADER -->
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Add New Inventory Item</h1>
        <p class="text-gray-600 mt-1">Add a new item to your inventory</p>
    </div>
    <a href="{{ path('app_inventory_index') }}" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors flex items-center gap-2">
        <span>←</span>
        <span>Back to Inventory</span>
    </a>
</div>

<!-- FORM -->
<div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6">
    {{ form_start(form, {'attr': {'class': 'space-y-6', 'enctype': 'multipart/form-data', 'data-turbo': 'false'}}) }}
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- BASIC INFO -->
        <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2">Basic Information</h3>
            
            <div>
                {{ form_label(form.product, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.product, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.product) }}
            </div>
            
            <div>
                {{ form_label(form.description, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.description, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.description) }}
            </div>
            
            <div>
                {{ form_label(form.category, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.category, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.category) }}
            </div>
            
            <div>
                {{ form_label(form.status, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.status, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.status) }}
            </div>
        </div>
        
        <!-- STOCK INFO -->
        <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2">Stock Information</h3>
            
            <div>
                {{ form_label(form.currentStock, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.currentStock, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.currentStock) }}
            </div>
            
            <div>
                {{ form_label(form.minimumStock, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.minimumStock, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.minimumStock) }}
            </div>
            
            <div>
                {{ form_label(form.maximumStock, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.maximumStock, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.maximumStock) }}
            </div>
            
            <div>
                {{ form_label(form.unit, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.unit, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.unit) }}
            </div>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- PRICING INFO -->
        <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2">Pricing Information</h3>
            
            <div>
                {{ form_label(form.unitPrice, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.unitPrice, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.unitPrice) }}
            </div>
        </div>
        
        <!-- SUPPLIE INFO -->
        <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2">Supplier Information</h3>
            
            <div>
                {{ form_label(form.supplier, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.supplier, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.supplier) }}
            </div>
            
            <div>
                {{ form_label(form.supplierContact, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.supplierContact, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.supplierContact) }}
            </div>
        </div>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- DATE INFO -->
        <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2">Date Information</h3>
            
            <div>
                {{ form_label(form.lastRestocked, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.lastRestocked, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.lastRestocked) }}
            </div>
            
            {# Expiry date removed as per requirements #}
        </div>
        
        <!-- IMAGE UPLOAD -->
        <div class="space-y-4">
            <h3 class="text-lg font-semibold text-gray-800 border-b border-gray-200 pb-2">Item Image</h3>
            
            <div>
                {{ form_label(form.imageFile, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                {{ form_widget(form.imageFile, {'attr': {'class': 'w-full px-3 py-2 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#235A2F]'}}) }}
                {{ form_errors(form.imageFile) }}
                <p class="text-xs text-gray-500 mt-1">Upload an image for this inventory item (optional)</p>
            </div>
        </div>
    </div>
    
    <!-- FORM BUTTONS -->
    <div class="flex items-center justify-end space-x-4 pt-6 border-t border-gray-200">
        <a href="{{ path('app_inventory_index') }}" class="bg-gray-500 text-white px-6 py-2 rounded-lg hover:bg-gray-600 transition-colors">
            Cancel
        </a>
        <button type="submit" class="bg-[#235A2F] text-white px-6 py-2 rounded-lg hover:bg-green-700 transition-colors">
            Create Item
        </button>
    </div>
    
    {{ form_end(form) }}
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const productSelect = document.querySelector('#inventory_product');
    
    if (!productSelect) {
        console.warn('Product select field not found');
        return;
    }
    
    function autoFillUnitPrice() {
        const productId = productSelect.value;
        
        if (!productId) {
            console.log('No product selected');
            return;
        }
        
        console.log('Fetching product details for ID:', productId);
        
        fetch(`{{ path('app_product_index') }}/${productId}/api/details`)
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                console.log('API Response:', data);
                
                if (data.unitPrice) {
                    // Find the actual money input field using multiple strategies
                    let moneyInput = null;
                    
                    // Strategy 1: Look for input with data-autofill attribute
                    moneyInput = document.querySelector('[data-autofill="unit-price"]');
                    
                    // Strategy 2: Look for inputs with class unit-price-input
                    if (!moneyInput) {
                        moneyInput = document.querySelector('.unit-price-input');
                    }
                    
                    // Strategy 3: Try multiple standard selectors
                    if (!moneyInput) {
                        const selectors = [
                            '#inventory_unitPrice_money',
                            '#inventory_unitPrice',
                            'input[name="inventory[unitPrice]"]',
                            'input[name="inventory[unitPrice][money]"]'
                        ];
                        
                        for (const selector of selectors) {
                            moneyInput = document.querySelector(selector);
                            if (moneyInput) break;
                        }
                    }
                    
                    // Strategy 4: Search by finding the label "Unit Price" and then its input
                    if (!moneyInput) {
                        const labels = document.querySelectorAll('label');
                        for (let label of labels) {
                            if (label.textContent.includes('Unit Price')) {
                                const container = label.closest('div');
                                if (container) {
                                    const inputs = container.querySelectorAll('input[type="text"], input[type="number"], input[type="hidden"]');
                                    if (inputs.length > 0) {
                                        moneyInput = inputs[0];
                                        break;
                                    }
                                }
                            }
                        }
                    }
                    
                    if (moneyInput) {
                        console.log('Found unitPrice input:', moneyInput);
                        console.log('Input attributes:', {
                            id: moneyInput.id,
                            name: moneyInput.name,
                            type: moneyInput.type,
                            classes: moneyInput.className
                        });
                        
                        // Set the value
                        moneyInput.value = data.unitPrice;
                        console.log('Set unitPrice to:', data.unitPrice);
                        
                        // Trigger events to notify listeners
                        moneyInput.dispatchEvent(new Event('input', { bubbles: true }));
                        moneyInput.dispatchEvent(new Event('change', { bubbles: true }));
                        moneyInput.dispatchEvent(new Event('blur', { bubbles: true }));
                        
                        // Focus and unfocus to trigger any onchange handlers
                        moneyInput.focus();
                        moneyInput.blur();
                    } else {
                        console.warn('Could not find unitPrice input field');
                        console.log('Debugging - all inputs in the page:');
                        const allInputs = document.querySelectorAll('input');
                        allInputs.forEach((input, idx) => {
                            if (input.name && input.name.includes('unitPrice')) {
                                console.log(`Input ${idx}:`, {
                                    id: input.id,
                                    name: input.name,
                                    type: input.type,
                                    value: input.value
                                });
                            }
                        });
                    }
                } else {
                    console.warn('No unitPrice in API response');
                }
            })
            .catch(error => {
                console.error('Error fetching product details:', error);
            });
    }
    
    // Auto-fill when product is selected
    productSelect.addEventListener('change', function() {
        console.log('Product selection changed to:', this.value);
        autoFillUnitPrice();
    });
    
    // Auto-fill on page load if product is already selected (for edit form)
    if (productSelect.value) {
        console.log('Product already selected on load:', productSelect.value);
        // Small delay to ensure DOM is fully ready
        setTimeout(autoFillUnitPrice, 100);
    }
});
</script>
{% endblock %}
