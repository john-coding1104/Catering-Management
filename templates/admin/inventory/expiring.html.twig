{% extends 'admin/layout.html.twig' %}

{% block admin_body %}
<!-- HEADER -->
<div class="flex items-center justify-between mb-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-800">Expiring Items</h1>
        <p class="text-gray-600 mt-1">Items expiring within the next 7 days</p>
    </div>
    <a href="{{ path('app_inventory_index') }}" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors flex items-center gap-2">
        <span>←</span>
        <span>Back to Inventory</span>
    </a>
</div>

<!-- EXPIRING ITEMS -->
{% if expiring_items|length > 0 %}
<div class="bg-red-50 border border-red-200 rounded-lg p-6 mb-6">
    <h2 class="text-xl font-semibold text-red-800 mb-4">📅 Expiring Items ({{ expiring_items|length }})</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {% for item in expiring_items %}
        <div class="bg-white rounded-lg p-4 border border-red-200">
            <h3 class="font-semibold text-gray-800">{{ item.name }}</h3>
            <p class="text-sm text-gray-600">{{ item.category }}</p>
            <p class="text-red-600 font-medium">
                Expires: {{ item.expiryDate|date('M d, Y') }}
                {% if item.isExpired() %}
                    <span class="text-red-800 font-bold">(EXPIRED)</span>
                {% endif %}
            </p>
            <p class="text-sm text-gray-500">Stock: {{ item.currentStock }} {{ item.unit }}</p>
            <a href="{{ path('app_inventory_show', {'id': item.id}) }}" class="text-blue-600 hover:text-blue-800 text-sm">View Details →</a>
        </div>
        {% endfor %}
    </div>
</div>
{% else %}
<div class="bg-green-50 border border-green-200 rounded-lg p-8 text-center">
    <div class="text-4xl mb-4">✅</div>
    <h2 class="text-xl font-semibold text-green-800 mb-2">No Expiring Items</h2>
    <p class="text-green-600">No items are expiring within the next 7 days.</p>
</div>
{% endif %}
{% endblock %}
