{% extends 'admin/layout.html.twig' %}

{% block admin_body %}
<div class="container mx-auto px-4 py-6">
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-3xl font-bold text-gray-800">{{ user.username }}</h1>
        <div class="flex gap-2">
        <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="bg-gray-500 text-white py-2 px-4 rounded-lg hover:bg-gray-600 transition-colors flex items-center gap-2">Edit</a>
        <a href="{{ path('app_user_index') }}" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition-colors flex items-center gap-2">
        <span>←</span>
        <span>Back</span>
    </a>
    </div>
    </div>


    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-lg shadow-sm p-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">User Information</h2>
            
            <div class="space-y-3">
                <div>
                    <label class="text-sm font-semibold text-gray-600">Username</label>
                    <p class="text-gray-900">{{ user.username }}</p>
                </div>

                <div>
                    <label class="text-sm font-semibold text-gray-600">Email</label>
                    <p class="text-gray-900">{{ user.email }}</p>
                </div>

                <div>
                    <label class="text-sm font-semibold text-gray-600">Status</label>
                    <p>
                        <span class="inline-block {% if user.status == 'active' %}bg-green-100 text-green-800{% else %}bg-red-100 text-red-800{% endif %} text-xs px-2 py-1 rounded">
                            {{ user.status|capitalize }}
                        </span>
                    </p>
                </div>

                <div>
                    <label class="text-sm font-semibold text-gray-600">Roles</label>
                    <div class="space-x-1">
                        {% for role in user.roles %}
                            {% if role != 'ROLE_USER' %}
                            <span class="inline-block bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">
                                {{ role == 'ROLE_ADMIN' ? 'Admin' : 'Staff' }}
                            </span>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>

                <div>
                    <label class="text-sm font-semibold text-gray-600">Created</label>
                    <p class="text-gray-900">{{ user.createdAt ? user.createdAt|date('Y-m-d H:i:s') : 'N/A' }}</p>
                </div>

                <div>
                    <label class="text-sm font-semibold text-gray-600">Updated</label>
                    <p class="text-gray-900">{{ user.updatedAt ? user.updatedAt|date('Y-m-d H:i:s') : 'N/A' }}</p>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-lg shadow-sm p-6">
            <h2 class="text-xl font-semibold text-gray-800 mb-4">Actions</h2>
            
            <div class="space-y-3">
                <form method="POST" action="{{ path('app_user_reset_password', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to reset this user\'s password?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('reset' ~ user.id) }}" />
                    <button type="submit" class="w-full bg-orange-600 hover:bg-orange-700 text-white font-bold py-2 px-4 rounded">
                        Reset Password
                    </button>
                </form>

                <form method="POST" action="{{ path('app_user_status', {'id': user.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('status' ~ user.id) }}" />
                    <button type="submit" class="w-full bg-{% if user.status == 'active' %}red{% else %}green{% endif %}-600 hover:bg-{% if user.status == 'active' %}red{% else %}green{% endif %}-700 text-white font-bold py-2 px-4 rounded">
                        {{ user.status == 'active' ? 'Disable Account' : 'Enable Account' }}
                    </button>
                </form>

                <form method="POST" action="{{ path('app_user_delete', {'id': user.id}) }}" onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}" />
                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-4 rounded">
                        Delete User
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
