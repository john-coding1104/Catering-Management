{% extends 'admin/layout.html.twig' %}

{% block title %}Activity Logs - User: {{ username }}{% endblock %}

{% block admin_body %}
<div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-bold text-gray-800">Activity Logs for User</h1>
            <p class="text-lg font-semibold text-gray-600 mt-1">{{ username }}</p>
        </div>
        <a href="{{ path('app_activity_logs_index') }}" class="inline-flex items-center rounded-md bg-gray-600 px-4 py-2 text-white hover:opacity-90">
            Back to All Logs
        </a>
    </div>

    <!-- Info Card -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
        <div class="text-sm text-gray-600">
            Total Activities: <span class="font-semibold text-lg">{{ total_count }}</span>
        </div>
    </div>

    <!-- Logs Table -->
    {% if logs|length > 0 %}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Timestamp</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Record Type</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Details</th>
                        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    {% for log in logs %}
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                {{ log.createdAt|date('Y-m-d H:i:s') }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm">
                                <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full
                                    {% if log.action == 'CREATE' %}
                                        bg-green-100 text-green-800
                                    {% elseif log.action == 'UPDATE' %}
                                        bg-blue-100 text-blue-800
                                    {% elseif log.action == 'DELETE' %}
                                        bg-red-100 text-red-800
                                    {% else %}
                                        bg-yellow-100 text-yellow-800
                                    {% endif %}
                                ">
                                    {{ log.action }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                {% if log.recordType %}
                                    <span class="bg-gray-100 text-gray-700 px-2 py-1 rounded text-xs font-medium">
                                        {{ log.recordType }}
                                    </span>
                                {% else %}
                                    <span class="text-gray-400">-</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600 max-w-xs truncate">
                                {{ log.targetData|default('-') }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                <a href="{{ path('app_activity_logs_show', {'id': log.id}) }}" class="text-[#235A2F] hover:text-[#1a4a26]">
                                    View
                                </a>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        {% if total_pages > 1 %}
            <div class="mt-6 flex justify-center gap-2">
                {% if page > 1 %}
                    <a href="{{ path('app_activity_logs_by_user', {'username': username, 'page': 1}) }}" class="px-3 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
                        First
                    </a>
                    <a href="{{ path('app_activity_logs_by_user', {'username': username, 'page': page - 1}) }}" class="px-3 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
                        Previous
                    </a>
                {% endif %}

                <span class="px-4 py-2 text-sm text-gray-600">
                    Page {{ page }} of {{ total_pages }}
                </span>

                {% if page < total_pages %}
                    <a href="{{ path('app_activity_logs_by_user', {'username': username, 'page': page + 1}) }}" class="px-3 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
                        Next
                    </a>
                    <a href="{{ path('app_activity_logs_by_user', {'username': username, 'page': total_pages}) }}" class="px-3 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50">
                        Last
                    </a>
                {% endif %}
            </div>
        {% endif %}
    {% else %}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-8 text-center">
            <p class="text-gray-600 text-lg">No activity logs found for this user.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
