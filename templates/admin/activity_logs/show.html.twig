{% extends 'admin/layout.html.twig' %}

{% block title %}Activity Log Details{% endblock %}

{% block admin_body %}
<div class="max-w-4xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Activity Log Details</h1>
        <a href="{{ path('app_activity_logs_index') }}" class="inline-flex items-center rounded-md bg-gray-600 px-4 py-2 text-white hover:opacity-90">
            Back to Logs
        </a>
    </div>

    <!-- Main Log Details -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Timestamp -->
            <div>
                <label class="block text-sm font-semibold text-gray-600">Timestamp</label>
                <p class="text-gray-900 mt-2 text-lg">{{ log.createdAt|date('Y-m-d H:i:s') }}</p>
            </div>

            <!-- Username -->
            <div>
                <label class="block text-sm font-semibold text-gray-600">User</label>
                <p class="text-gray-900 mt-2 text-lg">{{ log.username }}</p>
                {% if log.user %}
                    <a href="{{ path('app_activity_logs_by_user', {'username': log.username}) }}" class="text-[#235A2F] hover:text-[#1a4a26] text-sm mt-2">
                        View user's activity →
                    </a>
                {% endif %}
            </div>

            <!-- Role -->
            <div>
                <label class="block text-sm font-semibold text-gray-600">Role</label>
                <div class="mt-2">
                    <span class="inline-flex px-3 py-1 text-sm font-semibold rounded-full
                        {% if 'ADMIN' in log.role %}
                            bg-red-100 text-red-800
                        {% elseif 'STAFF' in log.role %}
                            bg-blue-100 text-blue-800
                        {% else %}
                            bg-gray-100 text-gray-800
                        {% endif %}
                    ">
                        {{ log.role }}
                    </span>
                </div>
            </div>

            <!-- Action -->
            <div>
                <label class="block text-sm font-semibold text-gray-600">Action</label>
                <div class="mt-2">
                    <span class="inline-flex px-3 py-1 text-sm font-semibold rounded-full
                        {% if log.action == 'CREATE' %}
                            bg-green-100 text-green-800
                        {% elseif log.action == 'UPDATE' or log.action == 'RESTOCK' or log.action == 'DESTOCK' %}
                            bg-blue-100 text-blue-800
                        {% elseif log.action == 'DELETE' %}
                            bg-red-100 text-red-800
                        {% elseif log.action == 'LOGIN' %}
                            bg-purple-100 text-purple-800
                        {% elseif log.action == 'LOGOUT' %}
                            bg-gray-100 text-gray-800
                        {% else %}
                            bg-yellow-100 text-yellow-800
                        {% endif %}
                    ">
                        {{ log.action }}
                    </span>
                </div>
            </div>

            <!-- Record Type -->
            {% if log.recordType %}
                <div>
                    <label class="block text-sm font-semibold text-gray-600">Record Type</label>
                    <p class="text-gray-900 mt-2 text-lg">{{ log.recordType }}</p>
                </div>

                <!-- Record ID -->
                <div>
                    <label class="block text-sm font-semibold text-gray-600">Record ID</label>
                    <p class="text-gray-900 mt-2 text-lg">{{ log.recordId }}</p>
                    <a href="{{ path('app_activity_logs_by_record', {'recordType': log.recordType, 'recordId': log.recordId}) }}" class="text-[#235A2F] hover:text-[#1a4a26] text-sm mt-2">
                        View record's full history →
                    </a>
                </div>
            {% endif %}
        </div>
    </div>

    <!-- Target Data / Changes -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4">Details</h2>
        <div class="bg-gray-50 p-4 rounded border border-gray-300">
            <p class="text-gray-900 whitespace-pre-wrap font-mono text-sm">
                {{ log.targetData|default('No additional details') }}
            </p>
        </div>
    </div>

    <!-- Related Logs -->
    {% if related_logs|length > 0 %}
        <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
            <h2 class="text-lg font-semibold text-gray-800 mb-4">Related Activity (Same Record)</h2>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Timestamp</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">User</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Action</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Details</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for relLog in related_logs %}
                            <tr class="hover:bg-gray-50">
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                                    {{ relLog.createdAt|date('Y-m-d H:i:s') }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                                    {{ relLog.username }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm">
                                    <span class="inline-flex px-2 py-1 text-xs font-semibold rounded-full
                                        {% if relLog.action == 'CREATE' %}
                                            bg-green-100 text-green-800
                                        {% elseif relLog.action == 'UPDATE' %}
                                            bg-blue-100 text-blue-800
                                        {% elseif relLog.action == 'DELETE' %}
                                            bg-red-100 text-red-800
                                        {% else %}
                                            bg-yellow-100 text-yellow-800
                                        {% endif %}
                                    ">
                                        {{ relLog.action }}
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-gray-600 max-w-xs truncate">
                                    {{ relLog.targetData|default('-') }}
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                    <a href="{{ path('app_activity_logs_show', {'id': relLog.id}) }}" class="text-[#235A2F] hover:text-[#1a4a26]">
                                        View
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}
</div>
{% endblock %}
