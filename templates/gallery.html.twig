{% extends "base.html.twig" %}

{% block title %}Gallery - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== HERO BREADCRUMB ========== -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-bold text-gray-900">Gallery</h1>
            <p class="text-gray-600 mt-2">Stunning catering setups and dining experiences</p>
        </div>
    </section>
    
    <!-- ========== GALLERY GRID ========== -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Gallery Item 1 - Large -->
                <div class="menu-item group cursor-pointer md:row-span-2 fade-in-up">
                    <img src="/images/wedding.jpg" alt="Wedding Reception" class="h-96 md:h-full">
                    <div class="menu-overlay">
                        <h4 class="text-white text-lg font-bold">Wedding Reception</h4>
                        <p class="text-gray-200 text-sm">Elegant table arrangements</p>
                    </div>
                </div>
                
                <!-- Gallery Item 2 -->
                <div class="menu-item group cursor-pointer fade-in-up">
                    <img src="/images/lecheflan.jpg" alt="Dessert Display">
                    <div class="menu-overlay">
                        <h4 class="text-white text-lg font-bold">Dessert Display</h4>
                        <p class="text-gray-200 text-sm">Sweet masterpieces</p>
                    </div>
                </div>
                
                <!-- Gallery Item 3 -->
                <div class="menu-item group cursor-pointer fade-in-up">
                    <img src="/images/appetizer.jpg" alt="Appetizers">
                    <div class="menu-overlay">
                        <h4 class="text-white text-lg font-bold">Appetizers</h4>
                        <p class="text-gray-200 text-sm">Perfect starters</p>
                    </div>
                </div>
                
                <!-- Gallery Item 4 -->
                <div class="menu-item group cursor-pointer fade-in-up">
                    <img src="/images/casual.jpeg" alt="Main Course">
                    <div class="menu-overlay">
                        <h4 class="text-white text-lg font-bold">Main Course</h4>
                        <p class="text-gray-200 text-sm">Signature dishes</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== TESTIMONIALS SECTION ========== -->
    <section class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16 fade-in-up">
                <h2 class="text-5xl font-bold text-gray-900 mb-4">What Our Clients Say</h2>
                <p class="text-lg text-gray-600 max-w-2xl mx-auto">
                    Hear from couples and event organizers who trusted Every Event with their special occasions
                </p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                <!-- Testimonial 1 -->
                <div class="bg-white p-8 rounded-lg shadow-sm fade-in-up">
                    <div class="flex items-center mb-4">
                        <div class="flex text-yellow-400">
                            <span>★★★★★</span>
                        </div>
                    </div>
                    <p class="text-gray-600 mb-6">
                        "Every Event made our wedding day absolutely perfect. The food was exquisite, the presentation was elegant, and the service was impeccable. We couldn't have asked for more!"
                    </p>
                    <div class="border-t border-gray-200 pt-4">
                        <p class="font-semibold text-gray-900">Maria & Juan Lopez</p>
                        <p class="text-sm text-gray-600">Wedding - June 2025</p>
                    </div>
                </div>
                
                <!-- Testimonial 2 -->
                <div class="bg-white p-8 rounded-lg shadow-sm fade-in-up">
                    <div class="flex items-center mb-4">
                        <div class="flex text-yellow-400">
                            <span>★★★★★</span>
                        </div>
                    </div>
                    <p class="text-gray-600 mb-6">
                        "The corporate catering for our annual gala was outstanding. Professional staff, delicious food, and seamless coordination. We'll definitely be booking with them again!"
                    </p>
                    <div class="border-t border-gray-200 pt-4">
                        <p class="font-semibold text-gray-900">Robert Chen</p>
                        <p class="text-sm text-gray-600">Corporate Event - April 2025</p>
                    </div>
                </div>
                
                <!-- Testimonial 3 -->
                <div class="bg-white p-8 rounded-lg shadow-sm fade-in-up">
                    <div class="flex items-center mb-4">
                        <div class="flex text-yellow-400">
                            <span>★★★★★</span>
                        </div>
                    </div>
                    <p class="text-gray-600 mb-6">
                        "Every Event transformed our intimate birthday celebration into a memorable culinary experience. The customized menu was creative, and every detail was perfect!"
                    </p>
                    <div class="border-t border-gray-200 pt-4">
                        <p class="font-semibold text-gray-900">Andrea Santos</p>
                        <p class="text-sm text-gray-600">Birthday Party - March 2025</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== CTA SECTION ========== -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center fade-in-up">
                <h2 class="text-4xl font-bold text-gray-900 mb-6">Create Your Own Memorable Event</h2>
                <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">
                    Let Every Event be part of your special occasion. Contact us today to get started!
                </p>
                <a href="{{ path('app_contact') }}" class="cta-button">Book Your Event</a>
            </div>
        </div>
    </section>
{% endblock %}
