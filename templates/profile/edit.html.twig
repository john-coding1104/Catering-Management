{% extends 'admin/layout.html.twig' %}

{% block title %}Edit Profile{% endblock %}

{% block admin_body %}
<div class="container mx-auto px-4 py-6">
    <div class="flex items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-800">Edit Profile</h1>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 max-w-2xl">
        <form method="POST" class="space-y-4">
            <input type="hidden" name="_token" value="{{ csrf_token('edit_profile') }}" />

            <div>
                <label for="username" class="block text-sm font-semibold text-gray-600 mb-2">Username</label>
                <input type="text" id="username" name="username" value="{{ user.username }}" class="w-full px-3 py-2 border border-gray-300 rounded">
            </div>

            <div>
                <label for="email" class="block text-sm font-semibold text-gray-600 mb-2">Email</label>
                <input type="email" id="email" name="email" value="{{ user.email }}" class="w-full px-3 py-2 border border-gray-300 rounded">
            </div>

            <div class="flex gap-2 pt-4">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">Update Profile</button>
                <a href="{{ path('app_profile_show') }}" class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded">Cancel</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
