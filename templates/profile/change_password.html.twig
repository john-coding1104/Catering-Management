{% extends 'admin/layout.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block admin_body %}
<div class="container mx-auto px-4 py-6">
    <div class="flex items-center mb-6">
        <h1 class="text-3xl font-bold text-gray-800">Change Password</h1>
    </div>

    <div class="bg-white rounded-lg shadow-sm p-6 max-w-2xl">
        {{ form_start(form, {'attr': {'class': 'space-y-4'}}) }}

        <div>
            {{ form_label(form.currentPassword) }}
            {{ form_widget(form.currentPassword, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded'}}) }}
            {{ form_errors(form.currentPassword) }}
        </div>

        <div>
            {{ form_label(form.plainPassword) }}
            {{ form_widget(form.plainPassword, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded'}}) }}
            {{ form_errors(form.plainPassword) }}
        </div>

        <div>
            {{ form_label(form.confirmPassword) }}
            {{ form_widget(form.confirmPassword, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded'}}) }}
            {{ form_errors(form.confirmPassword) }}
        </div>

        <div class="flex gap-2 pt-4">
            <button type="submit" class="bg-green-500 hover:bg-green-600 text-white font-bold py-2 px-4 rounded">Change Password</button>
            <a href="{{ path('app_profile_show') }}" class="bg-red-500 hover:bg-red-600 text-white font-bold py-2 px-4 rounded">Cancel</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
