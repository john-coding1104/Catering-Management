{% extends "base.html.twig" %}

{% block title %}Contact Us - Every Event | Premium Catering & Events{% endblock %}

{% block body %}
    <!-- ========== HERO BREADCRUMB ========== -->
    <section class="py-12 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <h1 class="text-4xl font-bold text-gray-900">Contact Us</h1>
            <p class="text-gray-600 mt-2">Get in touch to discuss your catering needs</p>
        </div>
    </section>
    
    <!-- ========== CONTACT SECTION ========== -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                <!-- Left Content -->
                <div class="fade-in-up">
                    <h2 class="text-5xl font-bold text-gray-900 mb-6 leading-tight">
                        Let's Create<br>Something Special
                    </h2>
                    <p class="text-base text-gray-600 mb-4 leading-relaxed">
                        We offer catering services and accept online booking. Through your comfort, we're passionate about bringing the vibrant flavors of Filipino cuisine right to your doorstep.
                    </p>
                    <p class="text-base text-gray-600 mb-8 leading-relaxed">
                        Our dedicated team is ready to help you plan the perfect event. Contact us today to discuss your vision and get a customized quote.
                    </p>
                    
                    <!-- Contact Info -->
                    <div class="space-y-6 mb-8">
                        <div class="flex items-start gap-4">
                            <svg class="w-6 h-6 text-red-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/>
                            </svg>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">Phone</p>
                                <p class="text-sm text-gray-600">+1 (555) 123-4567</p>
                                <p class="text-sm text-gray-600">WhatsApp: +1 (555) 987-6543</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <svg class="w-6 h-6 text-red-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                            </svg>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">Email</p>
                                <p class="text-sm text-gray-600">info@everyevent.com</p>
                                <p class="text-sm text-gray-600">catering@everyevent.com</p>
                            </div>
                        </div>
                        
                        <div class="flex items-start gap-4">
                            <svg class="w-6 h-6 text-red-400 mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                            </svg>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">Location</p>
                                <p class="text-sm text-gray-600">Dumaguete City, Philippines</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Right Form -->
                <div class="bg-gray-50 p-8 rounded-lg fade-in-up">
                    <h3 class="text-2xl font-bold text-gray-900 mb-6">Send us a Message</h3>
                    
                    <form id="contactForm" class="space-y-5">
                        <div>
                            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                            <input type="text" id="name" name="name" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400">
                        </div>
                        
                        <div>
                            <label for="email" class="block text-sm font-medium text-gray-700 mb-2">Email</label>
                            <input type="email" id="email" name="email" required class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400">
                        </div>
                        
                        <div>
                            <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                            <input type="tel" id="phone" name="phone" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400">
                        </div>
                        
                        <div>
                            <label for="eventDate" class="block text-sm font-medium text-gray-700 mb-2">Preferred Event Date</label>
                            <input type="date" id="eventDate" name="eventDate" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400">
                        </div>
                        
                        <div>
                            <label for="guestCount" class="block text-sm font-medium text-gray-700 mb-2">Number of Guests</label>
                            <select id="guestCount" name="guestCount" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400">
                                <option value="">Select...</option>
                                <option value="10-25">10 - 25 guests</option>
                                <option value="25-50">25 - 50 guests</option>
                                <option value="50-100">50 - 100 guests</option>
                                <option value="100-200">100 - 200 guests</option>
                                <option value="200+">200+ guests</option>
                            </select>
                        </div>
                        
                        <div>
                            <label for="eventType" class="block text-sm font-medium text-gray-700 mb-2">Event Type</label>
                            <select id="eventType" name="eventType" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400">
                                <option value="">Select...</option>
                                <option value="wedding">Wedding</option>
                                <option value="corporate">Corporate Event</option>
                                <option value="birthday">Birthday Party</option>
                                <option value="engagement">Engagement Party</option>
                                <option value="private">Private Party</option>
                                <option value="other">Other</option>
                            </select>
                        </div>
                        
                        <div>
                            <label for="message" class="block text-sm font-medium text-gray-700 mb-2">Message</label>
                            <textarea id="message" name="message" rows="5" placeholder="Tell us about your event and any special requests..." class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-400"></textarea>
                        </div>
                        
                        <button type="submit" class="w-full cta-button">Send Message</button>
                    </form>
                </div>
            </div>
        </div>
    </section>
    
    <!-- ========== MAP SECTION ========== -->
    <section class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-12 fade-in-up">
                <h2 class="text-4xl font-bold text-gray-900 mb-4">Find Us</h2>
                <p class="text-lg text-gray-600">Visit our location in Dumaguete City</p>
            </div>
            
            <div class="rounded-lg overflow-hidden shadow-lg fade-in-up h-96">
                <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3926.891421345678!2d123.3114!3d9.3031!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x33addb571c50a5b5%3A0x0!2sDumaguete%20City!5e0!3m2!1sen!2sph!4v1234567890" width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
            </div>
        </div>
    </section>
{% endblock %}

{% block scripts %}
<script>
    document.getElementById('contactForm').addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Basic form validation
        const name = document.getElementById('name').value.trim();
        const email = document.getElementById('email').value.trim();
        const message = document.getElementById('message').value.trim();
        
        if (!name || !email || !message) {
            alert('Please fill in all required fields');
            return;
        }
        
        // Simple email validation
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(email)) {
            alert('Please enter a valid email address');
            return;
        }
        
        // Show success message
        alert('Thank you for your message! We will get back to you shortly.');
        document.getElementById('contactForm').reset();
    });
</script>
{% endblock %}
