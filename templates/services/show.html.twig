{% extends 'admin/layout.html.twig' %}

{% block title %}Services{% endblock %}

{% block admin_body %}
<div class="max-w-5xl mx-auto">
    <div class="flex items-center justify-between">
        <h1 class="text-xl font-semibold text-gray-800">Service Details</h1>
        <div class="space-x-2">
            <a href="{{ path('app_services_index') }}" class="inline-flex items-center rounded-md bg-gray-600 px-3 py-1.5 text-white hover:opacity-90">Back to list</a>
            <a href="{{ path('app_services_edit', {'id': service.id}) }}" class="inline-flex items-center rounded-md bg-emerald-600 px-3 py-1.5 text-white hover:opacity-90">Edit</a>
        </div>
    </div>

    <div class="mt-4 overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
        <table class="min-w-full table-auto text-sm">
            <tbody class="divide-y divide-gray-100 text-gray-800">
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">Id</th>
                    <td class="px-4 py-3">{{ service.id }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">Name</th>
                    <td class="px-4 py-3">{{ service.name }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">Description</th>
                    <td class="px-4 py-3">{{ service.description }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">EventType</th>
                    <td class="px-4 py-3">{{ service.eventType }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">BasePrice</th>
                    <td class="px-4 py-3">{{ service.basePrice }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">MinGuests</th>
                    <td class="px-4 py-3">{{ service.minGuests }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">MaxGuests</th>
                    <td class="px-4 py-3">{{ service.maxGuests }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">CreatedAt</th>
                    <td class="px-4 py-3">{{ service.createdAt ? service.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">UpdatedAt</th>
                    <td class="px-4 py-3">{{ service.updatedAt ? service.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                </tr>
                <tr>
                    <th class="w-48 bg-gray-50 px-4 py-3 text-left font-medium text-gray-600">Inventory Items Used</th>
                    <td class="px-4 py-3">
                        {% if service.inventory is defined and service.inventory|length > 0 %}
                            <ul class="list-disc pl-4">
                                {% for inventory in service.inventory %}
                                    <li>{{ inventory.name }}</li>
                                {% endfor %}
                            </ul>
                        {% else %}
                            <span class="text-gray-500">No inventory items linked.</span>
                        {% endif %}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="mt-4">
        {{ include('services/_delete_form.html.twig') }}
    </div>
</div>
{% endblock %}